@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<form id="antiForgeryForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

<style>
    main.py-4 {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }

    .forgot-page {
        min-height: calc(100vh - 80px);
        display: grid;
        place-items: center;
        padding: 56px 16px;
        background:
            radial-gradient(circle at 80% 8%, rgba(96, 165, 250, 0.22), transparent 32%),
            linear-gradient(180deg, #f8fcff 0%, #eef6ff 100%);
    }

    .forgot-card {
        width: min(520px, 100%);
        padding: 34px;
        border: 1px solid #dbe7f7;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 24px 70px rgba(37, 99, 235, 0.12);
        animation: forgotIn 360ms ease both;
    }

    .forgot-icon {
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
        margin-bottom: 18px;
        border-radius: 18px;
        color: #2563eb;
        background: #eef6ff;
        border: 1px solid #dbe7f7;
    }

    .forgot-card h1 {
        margin: 0 0 10px;
        color: #142033;
        font-weight: 900;
        letter-spacing: 0;
    }

    .forgot-card p {
        margin: 0 0 24px;
        color: #64748b;
        line-height: 1.7;
    }

    .forgot-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    body.dark-mode .forgot-page {
        background:
            radial-gradient(circle at 80% 8%, rgba(96, 165, 250, 0.14), transparent 32%),
            linear-gradient(180deg, #0b1220 0%, #0f172a 100%);
    }

    body.dark-mode .forgot-card {
        background: #101a2c;
        border-color: rgba(147, 197, 253, 0.18);
        box-shadow: 0 24px 70px rgba(2, 6, 23, 0.34);
    }

    body.dark-mode .forgot-card h1 {
        color: #eaf2ff;
    }

    body.dark-mode .forgot-card p {
        color: #9fb0c8;
    }

    body.dark-mode .forgot-icon {
        color: #93c5fd;
        background: rgba(96, 165, 250, 0.12);
        border-color: rgba(147, 197, 253, 0.20);
    }

    @@keyframes forgotIn {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<section class="forgot-page">
    <div class="forgot-card">
        <div class="forgot-icon">
            <i class="fas fa-key"></i>
        </div>
        <h1>Quên mật khẩu</h1>
        <p>Nhập email tài khoản của bạn. JobPortal sẽ gửi mã OTP để xác thực trước khi đặt lại mật khẩu.</p>

        <div id="forgotMessage" class="alert d-none" role="alert"></div>

        <label class="form-label" for="forgotEmail">
            <i class="fas fa-envelope me-2"></i>Email
        </label>
        <input type="email" class="form-control" id="forgotEmail" placeholder="Nhập email của bạn" autocomplete="email" />

        <div class="forgot-actions">
            <button type="button" class="btn btn-primary flex-grow-1" id="forgotSubmit">
                <i class="fas fa-paper-plane me-2"></i>Gửi mã OTP
            </button>
            <a class="btn btn-outline-primary" href="@Url.Action("Login", "Account")">Quay lại</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const forgotToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        function showForgotMessage(message, type) {
            const box = $('#forgotMessage');
            box.removeClass('d-none alert-success alert-danger alert-warning')
                .addClass('alert-' + type)
                .html('<i class="fas ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle') + ' me-2"></i>' + message);
        }

        function sendForgotOtp() {
            const email = $('#forgotEmail').val().trim();
            const button = $('#forgotSubmit');

            if (!email) {
                showForgotMessage('Vui lòng nhập email.', 'danger');
                return;
            }

            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                showForgotMessage('Email không hợp lệ.', 'danger');
                return;
            }

            button.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang gửi...');

            $.ajax({
                url: '@Url.Action("ForgotPassword", "Account")',
                type: 'POST',
                data: {
                    email: email,
                    __RequestVerificationToken: forgotToken
                },
                success: function(response) {
                    if (response.success) {
                        showForgotMessage(response.message, 'success');
                        setTimeout(function() {
                            window.location.href = '@Url.Action("VerifyOtp", "Account")?email=' + encodeURIComponent(email);
                        }, 900);
                    } else {
                        showForgotMessage(response.message || 'Không thể gửi mã OTP.', 'danger');
                        button.prop('disabled', false).html('<i class="fas fa-paper-plane me-2"></i>Gửi mã OTP');
                    }
                },
                error: function() {
                    showForgotMessage('Có lỗi xảy ra, vui lòng thử lại.', 'danger');
                    button.prop('disabled', false).html('<i class="fas fa-paper-plane me-2"></i>Gửi mã OTP');
                }
            });
        }

        $('#forgotSubmit').on('click', sendForgotOtp);
        $('#forgotEmail').on('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                sendForgotOtp();
            }
        });
    </script>
}
