@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var email = ViewBag.Email as string;
    var otpCode = ViewBag.OtpCode as string;
}

<style>
    :root {
        --primary: #2563eb;
        --primary-dark: #1d4ed8;
        --primary-light: #60a5fa;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f293b;
        --gray-900: #111827;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        --transition: all 0.3s ease;
    }

    body {
        background: inherit;
        min-height: 100vh;
    }

    .reset-wrapper {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background:
            radial-gradient(circle at 18% 10%, rgba(125, 211, 252, .22), transparent 30%),
            linear-gradient(135deg, #f8fcff 0%, #eef6ff 52%, #e7f2ff 100%);
        transition: background .25s ease, color .25s ease;
    }

    .reset-container {
        max-width: 500px;
        width: 100%;
        background: rgba(255, 255, 255, .96);
        border: 1px solid #dce8f7;
        border-radius: 24px;
        box-shadow: 0 24px 70px rgba(37, 99, 235, .12);
        overflow: hidden;
        animation: slideUp 0.5s ease;
        transition: background .25s ease, border-color .25s ease, box-shadow .25s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .reset-header {
        background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
        padding: 2.5rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .reset-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        transform: rotate(45deg);
    }

    .reset-header::after {
        content: '';
        position: absolute;
        bottom: -50%;
        left: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }

    .reset-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: white;
        margin-bottom: 0.5rem;
        position: relative;
        z-index: 1;
    }

    .reset-header p {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1rem;
        position: relative;
        z-index: 1;
    }

    .reset-body {
        padding: 2.5rem 2rem;
        background: #ffffff;
        transition: background .25s ease;
    }

    .email-info {
        background: #eef6ff;
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border: 1px solid #dcecff;
    }

    .email-info i {
        color: #2563eb;
        font-size: 1.2rem;
    }

    .email-info span {
        color: var(--gray-800);
        font-weight: 600;
        font-size: 1.1rem;
    }

    .attempts-info {
        display: none !important;
        background: #eff6ff;
        color: #1d4ed8;
        padding: 0.75rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border: 1px solid #bfdbfe;
        font-weight: 500;
    }

    .attempts-info.warning {
        background: #f8d7da;
        color: #721c24;
        border-color: #f5c6cb;
    }

    .attempts-info i {
        font-size: 1.1rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 0.5rem;
    }

    .form-label i {
        color: #2563eb;
        margin-right: 0.5rem;
    }

    .input-group {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        z-index: 1;
    }

    .form-control {
        width: 100%;
        padding: 0.9rem 1rem 0.9rem 2.8rem;
        border: 2px solid #dbe7f5;
        border-radius: 16px;
        font-size: 1rem;
        transition: var(--transition);
    }

    .form-control:focus {
        border-color: #60a5fa;
        outline: none;
        box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.16);
    }

    .form-control.error {
        border-color: var(--danger);
        animation: shake 0.5s ease;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }

    .password-toggle {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #94a3b8;
        background: transparent;
        border: none;
    }

    .password-toggle:hover {
        color: #2563eb;
    }

    .btn-reset {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
        color: white;
        border: none;
        border-radius: 16px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-reset:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px rgba(37, 99, 235, 0.28);
    }

    .btn-reset:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .password-strength {
        margin-top: 0.5rem;
        height: 5px;
        border-radius: 10px;
        background: var(--gray-200);
        overflow: hidden;
    }

    .password-strength-bar {
        height: 100%;
        width: 0;
        transition: var(--transition);
    }

    .strength-weak {
        background: var(--danger);
    }

    .strength-medium {
        background: var(--warning);
    }

    .strength-strong {
        background: var(--success);
    }

    .alert {
        padding: 1rem 1.5rem;
        border-radius: 16px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .alert-warning {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .spinner-border {
        display: inline-block;
        width: 1.2rem;
        height: 1.2rem;
        border: 0.2em solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spinner-border .75s linear infinite;
    }

    @@keyframes spinner-border {
        to { transform: rotate(360deg); }
    }

    .lock-message {
        text-align: center;
        padding: 2rem;
    }

    .lock-message i {
        font-size: 4rem;
        color: var(--danger);
        margin-bottom: 1rem;
    }

    .lock-message h3 {
        color: var(--gray-800);
        margin-bottom: 1rem;
    }

    .lock-message p {
        color: var(--gray-600);
        margin-bottom: 0.5rem;
    }

    .lock-message a {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.75rem 2rem;
        background: var(--primary);
        color: white;
        text-decoration: none;
        border-radius: 12px;
        transition: var(--transition);
    }

    .lock-message a:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
    }

    .success-animation {
        text-align: center;
        padding: 2rem;
    }

    .success-animation i {
        font-size: 5rem;
        color: var(--success);
        margin-bottom: 1rem;
    }

    .success-animation h3 {
        color: var(--success);
        margin-bottom: 1rem;
    }

    .success-animation .spinner-border {
        margin-top: 1.5rem;
        color: var(--success);
    }

    body.dark-mode .reset-wrapper {
        background:
            radial-gradient(circle at 80% 8%, rgba(96, 165, 250, .14), transparent 34%),
            linear-gradient(135deg, #0b1220 0%, #0f172a 50%, #111827 100%);
    }

    body.dark-mode .reset-container {
        background: #101a2c;
        border-color: rgba(147, 197, 253, .18);
        box-shadow: 0 28px 80px rgba(2, 6, 23, .36);
    }

    body.dark-mode .reset-header {
        background: linear-gradient(135deg, #2563eb 0%, #1e3a8a 100%);
    }

    body.dark-mode .reset-body,
    body.dark-mode .email-info {
        background: #101a2c;
    }

    body.dark-mode .email-info {
        background: rgba(15, 23, 42, .78);
        border-color: rgba(147, 197, 253, .22);
    }

    body.dark-mode .email-info span,
    body.dark-mode .form-label,
    body.dark-mode .lock-message h3 {
        color: #eaf2ff;
    }

    body.dark-mode .form-control {
        background: #0f172a;
        color: #eaf2ff;
        border-color: rgba(147, 197, 253, .22);
    }

    body.dark-mode .form-control:focus {
        background: #111827;
        border-color: #60a5fa;
        box-shadow: 0 0 0 4px rgba(96, 165, 250, .16);
    }

    body.dark-mode .password-strength {
        background: rgba(147, 197, 253, .14);
    }

    body.dark-mode #strengthText,
    body.dark-mode .lock-message p,
    body.dark-mode .success-animation p {
        color: #9fb0c8 !important;
    }

    body.dark-mode .success-animation h3 {
        color: #86efac;
    }
</style>

<div class="reset-wrapper">
    <div class="reset-container">
        <div class="reset-header">
            <h1><i class="fas fa-key me-2"></i>Đặt lại mật khẩu</h1>
            <p>Nhập mật khẩu mới cho tài khoản của bạn</p>
        </div>

        <div class="reset-body">
            <div class="email-info">
                <i class="fas fa-envelope"></i>
                <span>@email</span>
            </div>

            <!-- Thông báo lỗi -->
            <div id="message" class="alert" style="display: none;"></div>

            <!-- Theo dõi số lần lỗi nội bộ, không hiển thị ở bước đặt mật khẩu -->
            <div id="attemptsInfo" class="attempts-info">
                <i class="fas fa-shield-alt"></i>
                <span id="attemptsLeft">3</span>/3 lần thử còn lại
            </div>

            <!-- Form đặt mật khẩu mới -->
            <div id="resetForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="email" value="@email">
                <input type="hidden" id="otpCode" value="@otpCode">

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-lock"></i> Mật khẩu mới
                    </label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" class="form-control" id="newPassword" placeholder="Nhập mật khẩu mới" onkeyup="checkPasswordStrength()">
                        <button type="button" class="password-toggle" onclick="togglePassword('newPassword', 'toggleNewIcon')">
                            <i class="fas fa-eye" id="toggleNewIcon"></i>
                        </button>
                    </div>
                    <div class="password-strength">
                        <div class="password-strength-bar" id="strengthBar"></div>
                    </div>
                    <small id="strengthText" style="color: #666;"></small>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-lock"></i> Xác nhận mật khẩu
                    </label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" class="form-control" id="confirmPassword" placeholder="Nhập lại mật khẩu mới">
                        <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword', 'toggleConfirmIcon')">
                            <i class="fas fa-eye" id="toggleConfirmIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="button" class="btn-reset" id="resetBtn" onclick="resetPassword()">
                    <i class="fas fa-save"></i> Đặt lại mật khẩu
                </button>
            </div>

            <!-- Animation thành công -->
            <div id="successAnimation" style="display: none;">
                <div class="success-animation">
                    <i class="fas fa-check-circle"></i>
                    <h3>Đặt lại mật khẩu thành công!</h3>
                    <p>Đang chuyển đến trang đăng nhập...</p>
                    <div class="spinner-border"></div>
                </div>
            </div>

            <!-- Thông báo khóa tài khoản -->
            <div id="lockMessage" style="display: none;">
                <div class="lock-message">
                    <i class="fas fa-lock"></i>
                    <h3>Tài khoản đã bị khóa</h3>
                    <p>Bạn đã nhập sai mật khẩu 3 lần.</p>
                    <p>Vui lòng liên hệ Admin để được hỗ trợ.</p>
                    <a href="/Home/Index">Về trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let email = '@email';
        let otpCode = '@otpCode';
        let attemptsLeft = 3; // GIỚI HẠN 3 LẦN
        let isLocked = false;

        function togglePassword(inputId, iconId) {
            let input = document.getElementById(inputId);
            let icon = document.getElementById(iconId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        function checkPasswordStrength() {
            let password = document.getElementById('newPassword').value;
            let strengthBar = document.getElementById('strengthBar');
            let strengthText = document.getElementById('strengthText');
            
            let strength = 0;
            
            if (password.length >= 8) strength++;
            if (/[a-z]/.test(password)) strength++;
            if (/[A-Z]/.test(password)) strength++;
            if (/[0-9]/.test(password)) strength++;
            if (/[^a-zA-Z0-9]/.test(password)) strength++;
            
            strengthBar.className = 'password-strength-bar';
            
            switch(strength) {
                case 0:
                case 1:
                case 2:
                    strengthBar.style.width = '33%';
                    strengthBar.classList.add('strength-weak');
                    strengthText.innerText = 'Mật khẩu yếu';
                    break;
                case 3:
                case 4:
                    strengthBar.style.width = '66%';
                    strengthBar.classList.add('strength-medium');
                    strengthText.innerText = 'Mật khẩu trung bình';
                    break;
                case 5:
                    strengthBar.style.width = '100%';
                    strengthBar.classList.add('strength-strong');
                    strengthText.innerText = 'Mật khẩu mạnh';
                    break;
                default:
                    strengthBar.style.width = '0%';
                    strengthText.innerText = '';
            }
        }

        function showMessage(message, type) {
            let messageDiv = document.getElementById('message');
            messageDiv.style.display = 'flex';
            messageDiv.className = `alert alert-${type}`;
            
            let icon = '';
            switch(type) {
                case 'success':
                    icon = '<i class="fas fa-check-circle"></i>';
                    break;
                case 'danger':
                    icon = '<i class="fas fa-exclamation-circle"></i>';
                    break;
                case 'warning':
                    icon = '<i class="fas fa-exclamation-triangle"></i>';
                    break;
            }
            
            messageDiv.innerHTML = icon + message;
            
            setTimeout(function() {
                messageDiv.style.display = 'none';
            }, 5000);
        }

        function updateAttempts() {
            document.getElementById('attemptsLeft').innerText = attemptsLeft;
            let attemptsInfo = document.getElementById('attemptsInfo');
            
            if (attemptsLeft <= 1) {
                attemptsInfo.classList.add('warning');
            } else {
                attemptsInfo.classList.remove('warning');
            }
        }

        function lockAccount() {
            isLocked = true;
            document.getElementById('resetForm').style.display = 'none';
            document.getElementById('attemptsInfo').style.display = 'none';
            document.getElementById('lockMessage').style.display = 'block';
            
            // Gửi request khóa tài khoản
            let formData = new URLSearchParams();
            formData.append('email', email);
            
            fetch('/Account/LockAccount', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: formData.toString()
            })
            .then(response => response.json())
            .then(data => {
                console.log('Account locked:', data);
            })
            .catch(error => {
                console.error('Error locking account:', error);
            });
        }

        function resetPassword() {
            // Kiểm tra nếu đã bị khóa
            if (isLocked) {
                showMessage('Tài khoản đã bị khóa', 'danger');
                return;
            }

            // Kiểm tra số lần thử (3 lần)
            if (attemptsLeft <= 0) {
                lockAccount();
                return;
            }

            let newPassword = document.getElementById('newPassword').value;
            let confirmPassword = document.getElementById('confirmPassword').value;
            let resetBtn = document.getElementById('resetBtn');

            // Kiểm tra mật khẩu
            if (!newPassword || newPassword.trim() === '') {
                showMessage('Vui lòng nhập mật khẩu mới', 'warning');
                return;
            }

            if (newPassword.length < 6) {
                showMessage('Mật khẩu phải có ít nhất 6 ký tự', 'warning');
                return;
            }

            if (newPassword !== confirmPassword) {
                showMessage('Mật khẩu xác nhận không khớp', 'warning');
                return;
            }

            // Disable button
            resetBtn.disabled = true;
            resetBtn.innerHTML = '<span class="spinner-border"></span> Đang xử lý...';

            // Lấy token
            let token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            // Tạo form data
            let formData = new URLSearchParams();
            formData.append('email', email);
            formData.append('otpCode', otpCode);
            formData.append('newPassword', newPassword);

            console.log('Sending request...');

            // Gửi request
            fetch('/Account/ResetPassword', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            })
            .then(response => {
                console.log('Response status:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data);
                
                if (data.success) {
                    // Thành công
                    document.getElementById('resetForm').style.display = 'none';
                    document.getElementById('attemptsInfo').style.display = 'none';
                    document.getElementById('successAnimation').style.display = 'block';
                    
                    setTimeout(function() {
                        window.location.href = '/Account/Login';
                    }, 2000);
                } else {
                    // Thất bại - Giảm số lần thử
                    attemptsLeft--;
                    updateAttempts();
                    
                    showMessage(`${data.message} (Còn ${attemptsLeft} lần thử)`, 'danger');
                    
                    // Hiệu ứng lỗi
                    document.getElementById('newPassword').classList.add('error');
                    document.getElementById('confirmPassword').classList.add('error');
                    
                    setTimeout(function() {
                        document.getElementById('newPassword').classList.remove('error');
                        document.getElementById('confirmPassword').classList.remove('error');
                    }, 1000);
                    
                    // Xóa mật khẩu
                    document.getElementById('newPassword').value = '';
                    document.getElementById('confirmPassword').value = '';
                    
                    // Kiểm tra nếu hết lần thử (3 lần)
                    if (attemptsLeft <= 0) {
                        lockAccount();
                    } else {
                        resetBtn.disabled = false;
                        resetBtn.innerHTML = '<i class="fas fa-save"></i> Đặt lại mật khẩu';
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showMessage('Lỗi kết nối: ' + error.message, 'danger');
                
                resetBtn.disabled = false;
                resetBtn.innerHTML = '<i class="fas fa-save"></i> Đặt lại mật khẩu';
            });
        }

        // Focus vào ô mật khẩu khi load
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('newPassword').focus();
            updateAttempts();
        });
    </script>
}
