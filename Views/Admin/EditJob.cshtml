@model BTL_2.Models.ViewModels.EditJobViewModel

@{
    ViewData["Title"] = "Sửa tin tuyển dụng";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<style>
    :root {
        --primary: #7c8cff;
        --primary-dark: #5a67d8;
        --bg-gradient: linear-gradient(135deg, #9aaaff, #c3caff);
        --gray-100: #f5f7fb;
        --gray-200: #e5e7eb;
        --gray-500: #6b7280;
        --gray-700: #374151;
    }

    body {
        background: var(--bg-gradient);
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-wrapper {
        padding: 40px 0;
    }

    .form-card {
        max-width: 800px;
        margin: auto;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .form-header {
        text-align: center;
        margin-bottom: 25px;
    }

        .form-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-700);
        }

        .form-header p {
            color: var(--gray-500);
            font-size: 14px;
            margin-top: 5px;
        }

    .form-label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid var(--gray-200);
        padding: 10px;
        transition: 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(124,140,255,0.2);
        }

    .section-title {
        font-weight: 600;
        margin: 20px 0 10px;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-note {
        font-size: 13px;
        color: var(--gray-500);
        font-weight: normal;
        margin-left: 10px;
    }

    .btn-primary {
        background: var(--primary);
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

    .alert {
        border-radius: 10px;
    }

    .info-box {
        background: #e8f0fe;
        border-left: 4px solid var(--primary);
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
    }

        .info-box i {
            color: var(--primary);
            margin-right: 8px;
        }

    .current-image {
        margin-top: 15px;
        padding: 15px;
        border: 1px solid var(--gray-200);
        border-radius: 10px;
        background: #f8f9fa;
    }

        .current-image img {
            max-height: 150px;
            max-width: 100%;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

    .text-muted {
        color: var(--gray-500) !important;
    }
</style>

<div class="page-wrapper">
    <div class="form-card">
        <div class="form-header">
            <h1>✏️ Sửa tin tuyển dụng</h1>
            <p>Chỉ cần nhập những thông tin bạn muốn thay đổi, các trường để trống sẽ giữ nguyên giá trị cũ</p>
        </div>

        <div class="info-box">
            <i>ℹ️</i> <strong>Hướng dẫn:</strong> Bạn chỉ cần nhập những trường muốn cập nhật.
            Các trường để trống sẽ giữ nguyên dữ liệu cũ. Ảnh sẽ giữ nguyên nếu không chọn ảnh mới.
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <form asp-action="EditJob" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="JobId" />
            <input type="hidden" asp-for="JobImage" />

            <!-- Title -->
            <div class="mb-3">
                <label asp-for="Title" class="form-label">
                    Tiêu đề <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề mới..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <!-- Company -->
            <div class="mb-3">
                <label asp-for="CompanyId" class="form-label">
                    Công ty <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <select asp-for="CompanyId" class="form-select"
                        asp-items="@(new SelectList(Model.Companies, "CompanyId", "CompanyName"))">
                    <option value="">-- Giữ nguyên công ty hiện tại --</option>
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <!-- Location -->
            <div class="mb-3">
                <label asp-for="Location" class="form-label">
                    Địa điểm <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <input asp-for="Location" class="form-control" placeholder="Nhập địa điểm mới..." />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <!-- JobType -->
            <div class="mb-3">
                <label asp-for="JobType" class="form-label">
                    Loại công việc <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <select asp-for="JobType" class="form-select">
                    <option value="">-- Giữ nguyên loại công việc hiện tại --</option>
                    <option value="Full-time">Full-time (Toàn thời gian)</option>
                    <option value="Part-time">Part-time (Bán thời gian)</option>
                    <option value="Remote">Remote (Làm việc từ xa)</option>
                    <option value="Hybrid">Hybrid (Kết hợp)</option>
                    <option value="Freelance">Freelance (Tự do)</option>
                    <option value="Internship">Internship (Thực tập)</option>
                    <option value="Contract">Contract (Hợp đồng)</option>
                </select>
                <span asp-validation-for="JobType" class="text-danger"></span>
            </div>

            <!-- Salary -->
            <div class="section-title">
                💰 Mức lương
                <span class="section-note">(Để trống nếu không muốn thay đổi)</span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SalaryMin" class="form-label">Từ</label>
                    <input asp-for="SalaryMin" type="number" class="form-control" placeholder="Lương tối thiểu..." />
                    <span asp-validation-for="SalaryMin" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="SalaryMax" class="form-label">Đến</label>
                    <input asp-for="SalaryMax" type="number" class="form-control" placeholder="Lương tối đa..." />
                    <span asp-validation-for="SalaryMax" class="text-danger"></span>
                </div>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label asp-for="Description" class="form-label">
                    Mô tả <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả mới..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- Requirement -->
            <div class="mb-3">
                <label asp-for="Requirement" class="form-label">
                    Yêu cầu <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <textarea asp-for="Requirement" class="form-control" rows="4" placeholder="Nhập yêu cầu mới..."></textarea>
                <span asp-validation-for="Requirement" class="text-danger"></span>
            </div>

            <!-- Benefit -->
            <div class="mb-3">
                <label asp-for="Benefit" class="form-label">
                    Quyền lợi <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <textarea asp-for="Benefit" class="form-control" rows="4" placeholder="Nhập quyền lợi mới..."></textarea>
                <span asp-validation-for="Benefit" class="text-danger"></span>
            </div>

            <!-- Skills -->
            <div class="mb-3">
                <label asp-for="Skills" class="form-label">
                    Kỹ năng yêu cầu <span class="text-muted small">(Chọn để thay đổi)</span>
                </label>
                <select asp-for="Skills" class="form-select">
                    <option value="">-- Giữ nguyên kỹ năng hiện tại (@Model.Skills) --</option>
                    <option value="C#">C#</option>
                    <option value="Java">Java</option>
                    <option value="Python">Python</option>
                    <option value="JavaScript">JavaScript</option>
                    <option value="PHP">PHP</option>
                    <option value="Ruby">Ruby</option>
                    <option value="SQL">SQL</option>
                    <option value="HTML/CSS">HTML/CSS</option>
                    <option value="React">React</option>
                    <option value="Angular">Angular</option>
                    <option value="Vue.js">Vue.js</option>
                    <option value="Node.js">Node.js</option>
                    <option value=".NET">.NET</option>
                    <option value="C++">C++</option>
                    <option value="TypeScript">TypeScript</option>
                    <option value="Go">Go</option>
                    <option value="AWS">AWS</option>
                    <option value="Docker">Docker</option>
                    <option value="Kubernetes">Kubernetes</option>
                </select>
                <span asp-validation-for="Skills" class="text-danger"></span>
                <div class="mt-2">
                    <input type="text" id="customSkill" class="form-control" placeholder="Hoặc nhập kỹ năng khác..." />
                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addCustomSkill()">➕ Thêm kỹ năng</button>
                </div>
            </div>

            <!-- Experience -->
            <div class="mb-3">
                <label asp-for="Experience" class="form-label">
                    Kinh nghiệm <span class="text-muted small">(Chọn để thay đổi)</span>
                </label>
                <select asp-for="Experience" class="form-select">
                    <option value="">-- Giữ nguyên kinh nghiệm hiện tại (@Model.Experience) --</option>
                    <option value="Không yêu cầu">Không yêu cầu</option>
                    <option value="Dưới 1 năm">Dưới 1 năm</option>
                    <option value="1 năm">1 năm</option>
                    <option value="2 năm">2 năm</option>
                    <option value="3 năm">3 năm</option>
                    <option value="4 năm">4 năm</option>
                    <option value="5 năm">5 năm</option>
                    <option value="Trên 5 năm">Trên 5 năm</option>
                    <option value="Trên 10 năm">Trên 10 năm</option>
                </select>
                <span asp-validation-for="Experience" class="text-danger"></span>
            </div>

            <!-- Education -->
            <div class="mb-3">
                <label asp-for="Education" class="form-label">
                    Trình độ học vấn <span class="text-muted small">(Chọn để thay đổi)</span>
                </label>
                <select asp-for="Education" class="form-select">
                    <option value="">-- Giữ nguyên trình độ hiện tại (@Model.Education) --</option>
                    <option value="Không yêu cầu">Không yêu cầu</option>
                    <option value="Trung học">Trung học</option>
                    <option value="Trung cấp">Trung cấp</option>
                    <option value="Cao đẳng">Cao đẳng</option>
                    <option value="Đại học">Đại học</option>
                    <option value="Cử nhân">Cử nhân</option>
                    <option value="Kỹ sư">Kỹ sư</option>
                    <option value="Thạc sĩ">Thạc sĩ</option>
                    <option value="Tiến sĩ">Tiến sĩ</option>
                </select>
                <span asp-validation-for="Education" class="text-danger"></span>
            </div>

            <!-- NumberOfRecruits -->
            <div class="mb-3">
                <label asp-for="NumberOfRecruits" class="form-label">
                    Số lượng tuyển <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <input asp-for="NumberOfRecruits" type="number" class="form-control" placeholder="Nhập số lượng..." />
                <span asp-validation-for="NumberOfRecruits" class="text-danger"></span>
            </div>

            <!-- Deadline -->
            <div class="mb-3">
                <label asp-for="Deadline" class="form-label">
                    Hạn nộp hồ sơ <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <input asp-for="Deadline" type="date" class="form-control" />
                <span asp-validation-for="Deadline" class="text-danger"></span>
            </div>

            <!-- Job Image - KHÔNG BẮT BUỘC -->
            <div class="mb-3">
                <label asp-for="JobImageFile" class="form-label">
                    Hình ảnh công việc <span class="text-muted small">(Không bắt buộc - chỉ chọn nếu muốn thay đổi ảnh)</span>
                </label>
                <input asp-for="JobImageFile" type="file" class="form-control" accept="image/*" />
                
                @if (!string.IsNullOrEmpty(Model.JobImage))
                {
                    <div class="current-image">
                        <p class="mb-2"><strong>🖼️ Ảnh hiện tại:</strong></p>
                        <img src="@Model.JobImage" alt="Job Image" />
                        <p class="text-muted mt-2 mb-0">
                            <i>✓ Ảnh này sẽ được giữ nguyên nếu bạn không chọn ảnh mới</i>
                        </p>
                    </div>
                }
                else
                {
                    <div class="mt-2 text-muted">
                        <p>ℹ️ Chưa có ảnh cho tin tuyển dụng này</p>
                    </div>
                }
            </div>

            <!-- VideoUrl -->
            <div class="mb-3">
                <label asp-for="VideoUrl" class="form-label">
                    Video giới thiệu (URL) <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <input asp-for="VideoUrl" class="form-control" placeholder="https://www.youtube.com/..." />
                <span asp-validation-for="VideoUrl" class="text-danger"></span>
            </div>

            <!-- Tags -->
            <div class="mb-3">
                <label asp-for="Tags" class="form-label">
                    Tags <span class="text-muted small">(Để trống nếu không muốn thay đổi)</span>
                </label>
                <input asp-for="Tags" class="form-control" placeholder="Ví dụ: IT, Marketing, Kế toán..." />
                <span asp-validation-for="Tags" class="text-danger"></span>
            </div>

            <!-- Options -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        <label asp-for="IsFeatured" class="form-check-label">🌟 Tin nổi bật</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="IsUrgent" class="form-check-input" />
                        <label asp-for="IsUrgent" class="form-check-label">⚠️ Tin khẩn cấp</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="IsRemote" class="form-check-input" />
                        <label asp-for="IsRemote" class="form-check-label">🏠 Làm việc từ xa</label>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    🚀 Cập nhật tin tuyển dụng
                </button>
                <a asp-action="ManageJobs" class="btn btn-outline-secondary">← Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Hàm thêm kỹ năng tùy chỉnh
        function addCustomSkill() {
            var customSkill = document.getElementById('customSkill').value.trim();
            if (customSkill) {
                var select = document.getElementById('Skills');
                
                // Kiểm tra xem kỹ năng đã tồn tại chưa
                var exists = false;
                for (var i = 0; i < select.options.length; i++) {
                    if (select.options[i].value.toLowerCase() === customSkill.toLowerCase()) {
                        exists = true;
                        break;
                    }
                }
                
                if (!exists) {
                    var option = document.createElement('option');
                    option.value = customSkill;
                    option.text = customSkill;
                    option.selected = true;
                    select.add(option);
                    document.getElementById('customSkill').value = '';
                    
                    // Thông báo thành công
                    alert('✅ Đã thêm kỹ năng: ' + customSkill);
                } else {
                    alert('⚠️ Kỹ năng này đã có trong danh sách!');
                }
            } else {
                alert('❌ Vui lòng nhập kỹ năng!');
            }
        }
    </script>
}