@{
    ViewData["Title"] = "CV đã được bảo vệ";
}

<div class="container py-5">
    <div class="card mx-auto" style="max-width: 760px;">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-success text-white" style="width: 48px; height: 48px;">
                    <i class="fas fa-check"></i>
                </div>
                <div>
                    <h1 class="h4 mb-1">CV đã được tải lên và mã hóa</h1>
                    <p class="text-muted mb-0">Metadata ID: <strong>#@ViewBag.CVId</strong></p>
                </div>
            </div>

            <div class="alert alert-success">
                File đã được lưu dưới dạng mã hóa. Link tải không được cấp trực tiếp cho ứng viên; nhà tuyển dụng phải tạo token phiên khi duyệt hồ sơ.
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="border rounded p-3 h-100">
                        <strong><i class="fas fa-fingerprint me-2 text-primary"></i>Metadata</strong>
                        <p class="text-muted small mb-0 mt-2">candidate_id, job_id, upload_time, expire_time và nonce được lưu kèm bản mã.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border rounded p-3 h-100">
                        <strong><i class="fas fa-shield-halved me-2 text-primary"></i>Toàn vẹn</strong>
                        <p class="text-muted small mb-0 mt-2">SHA-256 được kiểm tra trước khi giải mã file cho nhà tuyển dụng.</p>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a href="@Url.Action("MyApplications", "Account")" class="btn btn-primary">Xem hồ sơ đã ứng tuyển</a>
                <a href="@Url.Action("Index", "Jobs")" class="btn btn-outline-secondary ms-2">Tìm việc khác</a>
            </div>
        </div>
    </div>
</div>
