    @@keyframes revealUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .reveal {
        animation: revealUp 0.55s ease both;
    }

    @@media (max-width: 1199px) {
        .hero-photo-wrap {
            left: 18px;
        }

        .category-grid,
        .why-grid,
        .jobs-grid,
        .companies-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .news-layout {
            grid-template-columns: 1fr;
        }

        .career-band {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 991px) {
        .hero-section {
            padding: 72px 0 60px;
        }

        .hero-visual {
            min-height: 420px;
            margin-top: 34px;
        }

        .hero-photo-wrap {
            width: 100%;
            height: 100%;
        }

        .search-grid {
            grid-template-columns: 1fr;
        }

        .search-btn {
            width: 100%;
        }
    }

    @@media (max-width: 767px) {
        .home-section {
            padding: 52px 0;
        }

        .section-heading {
            display: block;
        }

        .section-heading .link-arrow {
            margin-top: 16px;
        }

            .category-grid,
            .why-grid,
            .jobs-grid,
            .companies-grid,
            .news-side,
            .career-stats {
                grid-template-columns: 1fr;
            }

        .hero-visual {
            min-height: 380px;
        }

        .hero-photo-wrap {
            inset: 0;
            border-width: 7px;
            border-radius: 24px;
        }

        .stat-card {
            grid-template-columns: 1fr 1fr 1fr;
            right: 14px;
            left: 14px;
            width: auto;
            bottom: 14px;
            padding: 10px;
        }

        .stat-card div {
            padding: 10px 8px;
        }

        .stat-card strong {
            font-size: 1rem;
        }

        .search-panel {
            border-radius: 18px;
        }

        .job-footer,
        .company-footer {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>

<div class="home-shell">
    <section class="hero-section">
        <div class="snow-layer" aria-hidden="true">
            @for (var i = 0; i < 34; i++)
            {
                var left = (i * 13) % 100;
                var size = 4 + (i % 5);
                var duration = 8 + (i % 8);
                var delay = -(i % 9);
                var drift = (i % 2 == 0 ? 28 : -24) + (i % 7);
                var opacity = 0.35 + ((i % 6) * 0.08);
                <span class="snowflake" style="--left:@(left)%;--size:@(size)px;--duration:@(duration)s;--delay:@(delay)s;--drift:@(drift)px;--opacity:@opacity;"></span>
            }
        </div>
        <div class="container hero-content">
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-home">@ViewBag.ErrorMessage</div>
            }

            <div class="row align-items-center g-5">
                <div class="col-lg-7 reveal">
                    <div class="hero-eyebrow">
                        @Icon("spark")
                        Nền tảng tuyển dụng tin cậy cho ứng viên Việt Nam
                    </div>
                    <h1 class="hero-title">Tìm việc làm phù hợp với bạn</h1>
                    <p class="hero-subtitle">
                        Khám phá việc làm chất lượng, công ty uy tín và cẩm nang nghề nghiệp giúp bạn ứng tuyển tự tin hơn mỗi ngày.
                    </p>

                    <form action="@Url.Action("Index", "Jobs")" method="get" class="search-panel">
                        <div class="search-grid">
                            <label class="search-field">
                                @Icon("search")
                                <input name="keyword" list="jobTitleOptions" placeholder="Tên công việc, kỹ năng hoặc công ty" autocomplete="off" />
                                <datalist id="jobTitleOptions">
                                    @foreach (var title in jobTitles.Take(20))
                                    {
                                        <option value="@title"></option>
                                    }
                                </datalist>
                            </label>

                            <label class="search-field">
                                @Icon("pin")
                                <select name="location" aria-label="Chọn địa điểm">
                                    <option value="">Tất cả địa điểm</option>
                                    @foreach (var location in locations)
                                    {
                                        <option value="@location">@location</option>
                                    }
                                </select>
                            </label>

                            <button type="submit" class="search-btn">
                                @Icon("search")
                                Tìm kiếm
                            </button>
                        </div>
                    </form>

                    <div class="quick-tags">
                        <strong>Từ khóa phổ biến:</strong>
                        @foreach (var tag in quickTags)
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = tag })">@tag</a>
                        }
                    </div>

                    <div class="trust-row">
                        <span>@Icon("check") Công ty xác thực</span>
                        <span>@Icon("check") Bảo mật CV</span>
                        <span>@Icon("check") Theo dõi ứng tuyển</span>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="hero-visual reveal" style="animation-delay: .12s">
                        <div class="hero-photo-wrap">
                            <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&w=1000&q=85" alt="Nhân viên văn phòng đang làm việc nhóm" />
                        </div>

                        <div class="floating-card stat-card">
                            <div>
                                <strong>@totalJobs.ToString("N0")+</strong>
                                <span>việc mới</span>
                            </div>
                            <div>
                                <strong>@totalCompanies.ToString("N0")+</strong>
                                <span>công ty</span>
                            </div>
                            <div>
                                <strong>24h</strong>
                                <span>phản hồi</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section">
        <div class="container">
            <div class="section-heading">
                <div>
                    <span class="section-kicker">@Icon("grid") Danh mục được quan tâm</span>
                    <h2>Khám phá việc làm theo ngành nghề</h2>
                    <p>Các lĩnh vực tuyển dụng phổ biến được trình bày rõ ràng để ứng viên tìm kiếm nhanh hơn.</p>
