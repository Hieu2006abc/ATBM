                </div>
                <a class="link-arrow" href="@Url.Action("Index", "Jobs")">Xem tất cả @Icon("arrow")</a>
            </div>

            <div class="jobs-grid">
                @if (displayJobs.Any())
                {
                    foreach (var job in displayJobs.Take(6))
                    {
                        var tags = BuildTags(job);
                        <article class="job-card">
                            <div class="job-company-row">
                                @if (!string.IsNullOrWhiteSpace(job.Company?.Logo))
                                {
                                    <img class="company-logo-img" src="@job.Company.Logo" alt="@job.Company?.CompanyName" />
                                }
                                else
                                {
                                    <span class="company-mark">@Initials(job.Company?.CompanyName)</span>
                                }
                                <div>
                                    <span class="company-name">@(job.Company?.CompanyName ?? "Đang cập nhật")</span>
                                    <span class="verified">@Icon("check") Đã xác thực</span>
                                </div>
                            </div>

                            <a class="job-title" href="@Url.Action("Details", "Jobs", new { id = job.JobId })">@job.Title</a>

                            <div class="job-meta">
                                <span class="salary">@Icon("wallet") @FormatSalary(job)</span>
                                <span>@Icon("pin") @(string.IsNullOrWhiteSpace(job.Location) ? "Linh hoạt" : job.Location)</span>
                                <span>@Icon("calendar") Hạn ứng tuyển: @(job.Deadline?.ToString("dd/MM/yyyy") ?? "30 ngày tới")</span>
                            </div>

                            <div class="tag-list">
                                @foreach (var tag in tags)
                                {
                                    <span class="tag">@tag</span>
                                }
