                                <a class="detail-btn" href="@Url.Action("Details", "Jobs", new { id = job.JobId })">Chi tiết</a>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="empty-state">Chưa có việc làm nổi bật để hiển thị.</div>
                }
            </div>
        </div>
