@{
    ViewData["Title"] = "Trang chủ";
    var featuredJobs = ViewBag.FeaturedJobs as List<BTL_2.Models.Job> ?? new List<BTL_2.Models.Job>();
    var latestJobs = ViewBag.LatestJobs as List<BTL_2.Models.Job> ?? new List<BTL_2.Models.Job>();
    var featuredCompanies = ViewBag.FeaturedCompanies as List<BTL_2.Models.Company> ?? new List<BTL_2.Models.Company>();
    var announcements = ViewBag.Announcements as List<BTL_2.Models.Announcement> ?? new List<BTL_2.Models.Announcement>();

    var locations = ViewBag.Locations as List<string> ?? new List<string> {
        "Hà Nội", "Hồ Chí Minh", "Đà Nẵng", "Hải Phòng", "Cần Thơ", "Remote"
    };

    var jobTitles = ViewBag.JobTitles as List<string> ?? new List<string> {
        ".NET Developer", "Java Developer", "Frontend Developer", "Backend Developer",
        "Fullstack Developer", "Mobile Developer", "DevOps Engineer", "Data Scientist",
        "QA Tester", "Business Analyst", "Project Manager", "Product Manager",
        "UI/UX Designer", "Marketing Executive", "Sales Executive", "HR Manager"
    };

    var displayJobs = featuredJobs.Any() ? featuredJobs : latestJobs;
    var quickTags = new[] { "Frontend", "Marketing", "Kế toán", "Thực tập sinh", "Remote" };
    var totalJobs = Math.Max(featuredJobs.Count + latestJobs.Count, 1280);
    var totalCompanies = Math.Max(featuredCompanies.Count, 320);
}

