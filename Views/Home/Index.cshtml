        background: rgba(96, 165, 250, 0.12);
        border-color: rgba(147, 197, 253, 0.20);
    }

    body.dark-mode .career-stat strong,
    body.dark-mode .salary,
    body.dark-mode .link-arrow,
    body.dark-mode .verified {
