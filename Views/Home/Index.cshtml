    body.dark-mode .hero-photo-wrap,
    body.dark-mode .floating-card,
    body.dark-mode .category-card,
    body.dark-mode .job-card,
    body.dark-mode .company-card,
    body.dark-mode .news-card,
    body.dark-mode .why-card,
    body.dark-mode .career-band,
    body.dark-mode .career-stat,
    body.dark-mode .stat-card div,
    body.dark-mode .side-card {
        color: #9fb0c8;
        background: #101a2c;
