@functions {
    private string FormatSalary(BTL_2.Models.Job job)
    {
        if (job.SalaryMin.HasValue && job.SalaryMax.HasValue)
        {
            return $"{job.SalaryMin.Value:N0} - {job.SalaryMax.Value:N0}";
        }

        if (job.SalaryMin.HasValue)
        {
            return $"Từ {job.SalaryMin.Value:N0}";
        }

        return "Lương thỏa thuận";
    }

    private string Initials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "JP";
        }

        var words = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 1)
        {
            return words[0].Substring(0, Math.Min(2, words[0].Length)).ToUpper();
        }

        return (words[0][0].ToString() + words[words.Length - 1][0].ToString()).ToUpper();
    }

    private string ShortText(string value, string fallback, int maxLength)
    {
        var text = string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
        return text.Length > maxLength ? text.Substring(0, maxLength).Trim() + "..." : text;
    }

    private bool IsRemoteCompany(BTL_2.Models.Company company)
    {
        return (company.Address ?? "").Contains("Remote", StringComparison.OrdinalIgnoreCase)
            || (company.Description ?? "").Contains("remote", StringComparison.OrdinalIgnoreCase);
    }

    private string[] BuildTags(BTL_2.Models.Job job)
    {
        var tags = new List<string>();

        if (!string.IsNullOrWhiteSpace(job.Tags))
        {
            tags.AddRange(job.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()).Where(t => t.Length > 0).Take(3));
        }

        if (!string.IsNullOrWhiteSpace(job.JobType))
        {
            tags.Add(job.JobType);
        }

        if (job.IsRemote || (job.Location ?? "").Contains("Remote", StringComparison.OrdinalIgnoreCase))
        {
            tags.Add("Remote");
        }
        else
        {
            tags.Add("Hybrid");
        }

        if (!tags.Any(t => t.Contains("Full", StringComparison.OrdinalIgnoreCase) || t.Contains("Toàn", StringComparison.OrdinalIgnoreCase)))
        {
            tags.Add("Full-time");
        }

        return tags.Distinct().Take(4).ToArray();
    }

