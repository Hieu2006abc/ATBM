                    <h3>Công nghệ thông tin</h3>
                    <p>248 việc làm đang mở</p>
                </a>
                <a class="category-card" href="@Url.Action("Index", "Jobs", new { keyword = "Kinh doanh" })">
                    <span class="category-icon">@Icon("briefcase")</span>
                    <h3>Kinh doanh</h3>
                    <p>186 việc làm đang mở</p>
                </a>
                <a class="category-card" href="@Url.Action("Index", "Jobs", new { keyword = "Kế toán" })">
                    <span class="category-icon">@Icon("chart")</span>
                    <h3>Kế toán - Tài chính</h3>
                    <p>112 việc làm đang mở</p>
                </a>
                <a class="category-card" href="@Url.Action("Index", "Jobs", new { keyword = "Marketing" })">
                    <span class="category-icon">@Icon("megaphone")</span>
                    <h3>Marketing</h3>
                    <p>95 việc làm đang mở</p>
