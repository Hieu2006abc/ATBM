    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
    
    <script>
        $(document).ready(function() {
        // Dark Mode Toggle
        function initDarkMode() {
        if ($('body').hasClass('security-dark-page')) {
        $('body').addClass('dark-mode');
        document.documentElement.classList.add('dark-mode-preload');
        document.documentElement.style.colorScheme = 'dark';
        return;
        }
        var darkMode = localStorage.getItem('darkMode');
        var enabled = darkMode === 'enabled';
        $('body').toggleClass('dark-mode', enabled);
        document.documentElement.classList.toggle('dark-mode-preload', enabled);
        document.documentElement.style.colorScheme = enabled ? 'dark' : 'light';
        window.setTimeout(function() {
        document.documentElement.classList.remove('theme-no-transition');
        }, 80);
        }

        $('#darkModeToggle').click(function() {
        if ($('body').hasClass('security-dark-page')) {
        $('body').addClass('dark-mode');
        document.documentElement.classList.add('dark-mode-preload');
        document.documentElement.style.colorScheme = 'dark';
        return;
        }
        var isDark = !$('body').hasClass('dark-mode');
        $('body').toggleClass('dark-mode', isDark);
        document.documentElement.classList.toggle('dark-mode-preload', isDark);
        document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
        localStorage.setItem('darkMode', isDark ? 'enabled' : 'disabled');
        });

        initDarkMode();

        // Load notifications
        function loadNotifications() {
        $.get('@Url.Action("GetNotifications", "Notification")', function(data) {
        var list = $('#notificationList');
        list.empty();
                    
        if (data.length === 0) {
        list.append('<div class="text-center p-4"><i class="fas fa-bell-slash fa-2x text-muted mb-2"></i><p class="text-muted">Không có thông báo</p></div>');
        return;
        }
                    
        data.forEach(function(notif) {
        var unreadClass = notif.isRead ? '' : 'unread';
        list.append(`
        <div class="notification-item ${unreadClass}" data-id="${notif.id}" onclick="markAsRead(${notif.id}, '${notif.linkUrl || '#'}')">
        <div class="d-flex">
        <div class="notification-icon ${notif.iconClass.split(' ')[1]} me-3">
        <i class="fas ${notif.iconClass.split(' ')[0]}"></i>
        </div>
        <div class="notification-content">
        <div class="notification-title">${notif.title}</div>
        <div class="notification-text">${notif.content}</div>
        <div class="notification-time">${notif.timeAgo}</div>
        </div>
        ${!notif.isRead ? '<span class="badge bg-primary ms-2" style="width: 8px; height: 8px; padding: 0;"></span>' : ''}
        </div>
        </div>
        `);
        });
                    
        // Update badge
        updateNotificationBadge();
        });
        }

        function updateNotificationBadge() {
        $.get('@Url.Action("GetUnreadCount", "Notification")', function(count) {
        var badge = $('#notificationBadge');
        if (count > 0) {
        badge.text(count).show();
        } else {
        badge.hide();
        }
        });
        }

        window.markAsRead = function(id, url) {
        $.post('@Url.Action("MarkAsRead", "Notification")',
        { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
        function() {
        if (url && url !== '#') {
        window.location.href = url;
        } else {
        loadNotifications();
        }
        }
        );
        };

        $('#markAllRead').click(function(e) {
        e.preventDefault();
        $.post('@Url.Action("MarkAllAsRead", "Notification")',
        { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
        function() {
        loadNotifications();
        }
        );
        });

        // Load chat conversations
        function loadChats() {
        $.get('@Url.Action("GetConversations", "Chat")', function(data) {
        var list = $('#chatList');
        list.empty();
                    
        if (data.length === 0) {
        list.append('<div class="text-center p-4"><i class="fas fa-comments fa-2x text-muted mb-2"></i><p class="text-muted">Chưa có tin nhắn</p></div>');
        return;
        }
                    
        data.forEach(function(chat) {
        list.append(`
        <div class="chat-item" onclick="window.location.href='@Url.Action("Index", "Chat")?conversation=${chat.conversationId}'">
        <div class="d-flex align-items-center">
        <img src="${chat.otherUserAvatar}" class="chat-avatar">
        <div class="chat-info">
        <div class="d-flex justify-content-between align-items-center">
        <span class="chat-name">${chat.otherUserName}</span>
        <span class="chat-time">${chat.timeAgo}</span>
        </div>
        <div class="d-flex justify-content-between align-items-center">
        <span class="chat-last-message">${chat.lastMessage || 'Chưa có tin nhắn'}</span>
        ${chat.unreadCount > 0 ? `<span class="chat-badge ms-2">${chat.unreadCount}</span>` : ''}
        </div>
        </div>
        </div>
        </div>
        `);
        });
                    
        // Update chat badge
        updateChatBadge();
        });
        }

        function updateChatBadge() {
        $.get('@Url.Action("GetUnreadMessageCount", "Chat")', function(count) {
        var badge = $('#chatBadge');
        if (count > 0) {
        badge.text(count).show();
        } else {
        badge.hide();
        }
        });
        }

        // Load data
        if ('@Context.Session.GetString("UserId")' !== '') {
        loadNotifications();
        loadChats();
                
        // Auto refresh every 30 seconds
        setInterval(function() {
        updateNotificationBadge();
        updateChatBadge();
        }, 30000);
                
        // Refresh when dropdown opens
        $('#notificationDropdown').parent().on('show.bs.dropdown', function() {
        loadNotifications();
        });
                
        $('#chatDropdown').parent().on('show.bs.dropdown', function() {
        loadChats();
        });
        }

        // Auto hide alerts
        setTimeout(function() {
        $('.alert').fadeOut(500, function() {
        $(this).remove();
        });
        }, 5000);

        // Update pending applications count for Admin
        @if (Context.Session.GetString("UserRole") == "Admin")
        {
            <text>
                $.get('@Url.Action("GetPendingCount", "Admin")', function(count) {
                $('#pendingApplicationsCount').text(count);
                });
            </text>
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
