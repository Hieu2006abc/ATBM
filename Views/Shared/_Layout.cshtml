                                            <i class="fas fa-file-alt me-2 text-info"></i>Việc đã ứng tuyển
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("SavedJobs", "Jobs")">
                                            <i class="fas fa-bookmark me-2 text-info"></i>Việc đã lưu
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }

                                <!-- Menu chung cho tất cả user -->
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Profile", "Account")">
                                        <i class="fas fa-user me-2"></i>Hồ sơ cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("ChangePassword", "Account")">
                                        <i class="fas fa-key me-2"></i>Đổi mật khẩu
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Profile", "Account", new { tab = "security" })">
                                        <i class="fas fa-shield-alt me-2"></i>Bảo mật 2FA
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-action="Logout" asp-controller="Account" method="post" id="logoutForm">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-primary me-2" href="@Url.Action("Login", "Account")">
                                Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary" href="@Url.Action("Register", "Account")">
                                Đăng ký
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            <a class="btn btn-employer" href="@Url.Action("Login", "Account", new { role = "employer", returnUrl = Url.Action("ManageApplications", "Jobs") })">
                                Nhà tuyển dụng
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null || TempData["WarningMessage"] != null)
    {
        <div class="app-toast-container" aria-live="polite" aria-atomic="true">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show app-toast" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show app-toast" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["WarningMessage"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show app-toast" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>@TempData["WarningMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    }

    <!-- Main Content -->
