                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ManageAnnouncements", "Admin")">
                                            <i class="fas fa-bullhorn me-2 text-primary"></i>Quản lý thông báo
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }

                                <!-- Menu dành cho Employer -->
                                @if (Context.Session.GetString("UserRole") == "Employer")
                                {
                                    <li><h6 class="dropdown-header bg-success text-white py-2 px-3">Nhà tuyển dụng</h6></li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ManageApplications", "Jobs")">
                                            <i class="fas fa-file-signature me-2 text-success"></i>Xem hồ sơ ứng tuyển
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }

                                <!-- Menu dành cho Candidate -->
                                @if (Context.Session.GetString("UserRole") == "Candidate")
                                {
                                    <li><h6 class="dropdown-header bg-info text-white py-2 px-3">Ứng viên</h6></li>
