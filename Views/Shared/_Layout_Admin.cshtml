<!DOCTYPE html>
@{
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var isSecurityDarkPage =
        requestPath.Contains("/Admin/CVAccessLogs", StringComparison.OrdinalIgnoreCase) ||
        requestPath.Contains("/TestSecurity", StringComparison.OrdinalIgnoreCase);
}
<html lang="vi" class="@(isSecurityDarkPage ? "security-dark-page" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobPortal Admin</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <style>
        html.security-dark-page,
        html.security-dark-page body {
            background: #0f172a !important;
            color: #e5e7eb !important;
        }

        body.security-dark-page {
            transition: none !important;
        }
    </style>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(isSecurityDarkPage ? "security-dark-page dark-mode" : "")">
    @await Html.PartialAsync("_PageLoader")
    <!-- Admin Layout - KHÔNG có navbar và footer của trang chủ -->
    <div style="min-height: 100vh;">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
