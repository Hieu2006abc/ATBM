@* Views/TestSecurity/TestResult.cshtml *@
@using BTL_2.Models.ViewModels
@model TestResultViewModel

<div class="container mt-5">
    <div class="card @(Model.Passed ? "border-success" : "border-danger")">
        <div class="card-header @(Model.Passed ? "bg-success" : "bg-danger") text-white">
            <h3>Kết quả kiểm thử: @Model.TestName</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5>✅ Kết quả mong đợi:</h5>
                    <p class="text-muted">@Model.ExpectedResult</p>
                </div>
                <div class="col-md-6">
                    <h5>📋 Kết quả thực tế:</h5>
                    <p class="@(Model.Passed ? "text-success" : "text-danger")">
                        @Model.ActualResult
                    </p>
                </div>
            </div>
            <hr />
            <div class="text-center">
                <h4>
                    @if (Model.Passed)
                    {
                        <span class="badge bg-success">✓ TEST PASSED</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">✗ TEST FAILED</span>
                    }
                </h4>
                <p class="text-muted">Thời gian: @Model.TestTime.ToString("dd/MM/yyyy HH:mm:ss")</p>
            </div>
        </div>
        <div class="card-footer">
            <a href="/TestSecurity/ViewTestLogs" class="btn btn-primary">Xem tất cả logs</a>
            <a href="/Jobs/ManageApplications" class="btn btn-secondary">Quay lại</a>
        </div>
    </div>
</div>