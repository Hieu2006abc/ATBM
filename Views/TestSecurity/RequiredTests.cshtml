@model List<BTL_2.Models.ViewModels.TestResultViewModel>
@{
    ViewData["Title"] = "Kết quả quét CV thật";
    var passCount = Model.Count(x => x.Passed);
    var totalCount = Model.Count;
    var integrityScan = ViewBag.IntegrityScan as List<BTL_2.Models.ViewModels.CVIntegrityScanItemViewModel>
        ?? new List<BTL_2.Models.ViewModels.CVIntegrityScanItemViewModel>();
}

<style>
    body {
        background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
        color: #e5e7eb;
    }

    .result-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .result-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .result-header h1 {
        margin: 0;
        color: #f8fafc;
        font-size: 1.55rem;
        font-weight: 800;
    }

    .score-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.5rem 0.85rem;
        background: @(passCount == totalCount ? "#dcfce7" : "#fee2e2");
        color: @(passCount == totalCount ? "#166534" : "#991b1b");
        font-weight: 900;
    }

    .result-card {
        background: rgba(15, 23, 42, 0.78);
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.22);
    }

    .result-table {
        margin: 0;
        color: #e5e7eb;
    }

    .result-table th {
        background: rgba(2, 6, 23, 0.88);
        color: #e2e8f0;
        text-transform: uppercase;
        font-size: 0.78rem;
        white-space: nowrap;
        padding: 0.9rem;
    }

    .result-table td {
        color: #dbeafe !important;
        background: rgba(15, 23, 42, 0.68) !important;
        border-color: rgba(148, 163, 184, 0.18);
        padding: 0.9rem;
        vertical-align: top;
    }

    .result-table tbody tr:nth-child(even) td {
        background: rgba(30, 41, 59, 0.62) !important;
    }

    .result-table .text-muted {
        color: #9fb0c7 !important;
    }

    .result-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .scan-title {
        color: #f8fafc;
        font-size: 1.15rem;
        font-weight: 800;
        margin: 1.25rem 0 0.75rem;
    }

    .scan-status {
        display: inline-flex;
        padding: 0.35rem 0.6rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 900;
    }

    .scan-status.ok {
        background: rgba(34, 197, 94, 0.16);
        color: #86efac;
        border: 1px solid rgba(34, 197, 94, 0.28);
    }

    .scan-status.fail {
        background: rgba(239, 68, 68, 0.16);
        color: #fecaca;
        border: 1px solid rgba(239, 68, 68, 0.28);
    }
</style>

<div class="result-shell">
    <div class="result-header">
        <h1><i class="fas fa-file-shield me-2"></i>Kết quả quét CV thật</h1>
        <span class="score-badge">@passCount/@totalCount PASS</span>
    </div>

    <div class="result-card table-responsive">
        <table class="table result-table">
            <thead>
                <tr>
                    <th>Kiểm tra</th>
                    <th>Kết quả mong đợi</th>
                    <th>Kết quả thực tế</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.TestName</td>
                        <td>@item.ExpectedResult</td>
                        <td>@item.ActualResult</td>
                        <td>
                            @if (item.Passed)
                            {
                                <span class="badge bg-success">PASS</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">FAIL</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (integrityScan.Any())
    {
        <div class="scan-title"><i class="fas fa-file-shield me-2"></i>Chi tiết quét toàn vẹn CV thật</div>
        <div class="result-card table-responsive">
            <table class="table result-table">
                <thead>
                    <tr>
                        <th>CV</th>
                        <th>Ứng viên</th>
                        <th>Công việc</th>
                        <th>Thời gian</th>
                        <th>Kết quả</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in integrityScan)
                    {
                        <tr>
                            <td>
                                <strong>#@item.CVMetadataId</strong> @item.OriginalFileName
                                @if (!string.IsNullOrWhiteSpace(item.StoredFileName))
                                {
                                    <div class="text-muted small" title="@item.FilePath">File thật trên server: @item.StoredFileName</div>
                                }
                                @if (item.ServerLastWriteTime.HasValue)
                                {
                                    <div class="text-muted small">
                                        Sửa lần cuối: @item.ServerLastWriteTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                        @if (item.ServerFileSize.HasValue)
                                        {
                                            <span>(@item.ServerFileSize.Value bytes)</span>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                <strong>@item.CandidateName</strong>
                                <div class="text-muted">@item.CandidateEmail</div>
                            </td>
                            <td>@item.JobTitle</td>
                            <td>
                                <div>Upload: @item.UploadTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div class="text-muted">Hết hạn: @item.ExpireTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td>
                                <span class="scan-status @(item.Passed ? "ok" : "fail")">@item.Status</span>
                            </td>
                            <td>@item.Detail</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="result-actions">
        <form asp-action="RunRequiredTests" asp-controller="TestSecurity" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Quét lại CV thật</button>
        </form>
        <a class="btn btn-outline-light" href="@Url.Action("ManageApplications", "Jobs")">
            Quay lại quản lý CV
        </a>
    </div>
</div>
